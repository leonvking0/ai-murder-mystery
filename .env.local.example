# AI Murder Mystery - Environment Variables
# Copy this file to .env.local and add your actual API keys

# LLM provider selection: google (default) | anthropic
LLM_PROVIDER=google

# --- Google Gemini (default) ---
# Free tier (no credit card): ~10 RPM / 250 requests-per-day / 250K TPM.
# Get a key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key
# Model id (stable). For higher-volume / multiplayer use gemini-2.5-flash-lite.
GOOGLE_MODEL=gemini-2.5-flash

# --- Anthropic Claude (optional alternative) ---
# ANTHROPIC_API_KEY=your_anthropic_api_key
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Persistence (self-host / Docker) ---
# SQLite file path; in Docker this lives on a mounted volume so games survive restarts.
DATABASE_PATH=./data/game.db
